{{- if (eq .chezmoi.os "linux") -}}
{{- if eq .chezmoi.osRelease.idLike "arch" -}}
#!/usr/bin/env bash

set -euo pipefail

LAUNCHER="/usr/local/bin/ambxst"

if [[ -f "$LAUNCHER" ]]; then
    echo "[ ~ ] Ambxst launcher already exists at $LAUNCHER"
    exit 0
fi

echo "[ ~ ] Creating Ambxst launcher at $LAUNCHER..."

sudo tee "$LAUNCHER" > /dev/null <<'SCRIPT'
#!/usr/bin/env bash
export PATH="$HOME/.local/bin:$PATH"
export QML2_IMPORT_PATH="$HOME/.local/lib/qml:$QML2_IMPORT_PATH"
export QML_IMPORT_PATH="$QML2_IMPORT_PATH"
exec "$HOME/.local/src/ambxst/cli.sh" "$@"
SCRIPT

sudo chmod +x "$LAUNCHER"

echo "[ ~ ] Ambxst launcher installed"

{{ end -}}
{{ end -}}
