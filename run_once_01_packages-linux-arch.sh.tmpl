{{- if (eq .chezmoi.os "linux") -}}
{{- if eq .chezmoi.osRelease.idLike "arch" -}}
#!/usr/bin/env bash

set -euo pipefail

echo "[ ~ ] Updating system packages..."
sudo pacman -Syu --noconfirm

echo "[ ~ ] Installing pacman packages..."
sudo pacman -S --needed --noconfirm - <<EOF
atuin
bash
blueman
breeze-gtk
brightnessctl
ca-certificates
cava
chezmoi
cliphist
curl
dart-sass
dolphin
dolphin-plugins
easyeffects
fastfetch
fcitx5
ffmpeg
firefox
fuzzel
fzf
gcc
git
gnupg
grep
gjs
glycin
glycin-gtk4
grim
gst-plugin-pipewire
gvfs
gtk3
gzip
imagemagick
iproute2
jq
kde-gtk-config
libadwaita
libcanberra
libnotify
kitty
kwayland-integration
mise
networkmanager
niri
xwayland-satellite
noto-fonts
noto-fonts-cjk
noto-fonts-emoji
openssl
pcre
pipewire-alsa
pipewire-jack
pipewire-pulse
playerctl
power-profiles-daemon
python-pipx
python-pyqt6
qt6-base
qt6ct
qt6-declarative
qt6-imageformats
qt6-multimedia-ffmpeg
qt6-wayland
readline
slurp
socat
sqlite
tcpdump
tesseract
tmux
ttf-roboto
ttf-roboto-mono
upower
uwsm
vlc
wl-clipboard
wlsunset
wireplumber
wtype
xdg-desktop-portal-gnome
xdg-desktop-portal-gtk
xdg-desktop-portal-kde
zbar
zenity
zlib
zsh
EOF

echo "[ ~ ] Pacman packages have been installed"

# Install yay if not present (needed for AUR packages)
if ! command -v yay &> /dev/null; then
    echo "[ ~ ] Installing yay AUR helper..."
    sudo pacman -S --needed --noconfirm git base-devel
    TMPDIR=$(mktemp -d)
    git clone https://aur.archlinux.org/yay.git "$TMPDIR/yay"
    (cd "$TMPDIR/yay" && makepkg -si --noconfirm)
    rm -rf "$TMPDIR"
fi

echo "[ ~ ] Installing AUR packages..."
# Prepend /usr/bin so yay resolves python3 to system Python (not mise's)
PATH="/usr/bin:/usr/sbin:$PATH" yay -S --needed --noconfirm \
    adw-gtk-theme \
    aylurs-gtk-shell-git \
    dms-shell-bin \
    libastal-meta \
    gpu-screen-recorder \
    gradia \
    matugen \
    mpvpaper \
    ttf-cascadia-code-nerd \
    ttf-jetbrains-mono-nerd \
    ttf-league-gothic \
    ttf-material-symbols-variable-git \
    ttf-phosphor-icons \
    wl-clip-persist

echo "[ ~ ] AUR packages have been installed"
echo "[ ~ ] All Linux packages have been installed"

{{ end -}}
{{ end -}}
