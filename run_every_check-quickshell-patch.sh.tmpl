{{- if (eq .chezmoi.os "linux") -}}
{{- if eq .chezmoi.osRelease.idLike "arch" -}}
#!/usr/bin/env bash
# Check if quickshell-git was updated without the QueuedConnection patch
# (upstream #580/#581 — SIGSEGV on monitor disconnect)

STAMP="$HOME/.cache/yay/quickshell-git/.patched-version"

if ! pacman -Q quickshell-git &>/dev/null; then
    exit 0
fi

INSTALLED=$(pacman -Q quickshell-git | awk '{print $2}')

if [[ -f "$STAMP" ]] && [[ "$(cat "$STAMP")" == "$INSTALLED" ]]; then
    exit 0
fi

PKGBUILD="$HOME/.cache/yay/quickshell-git/PKGBUILD"
if [[ -f "$PKGBUILD" ]] && grep -q 'queued-screen-updates.patch' "$PKGBUILD"; then
    echo "[ ~ ] quickshell-git $INSTALLED may be unpatched (screen disconnect fix)"
    echo "      run: rebuild-quickshell"
else
    echo "[ ~ ] quickshell-git $INSTALLED is unpatched AND PKGBUILD was overwritten"
    echo "      run: refresh && rebuild-quickshell"
fi
{{ end -}}
{{ end -}}
