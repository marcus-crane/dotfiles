{{- if (eq .chezmoi.os "linux") -}}
{{- if eq .chezmoi.osRelease.idLike "arch" -}}
#!/usr/bin/env bash

# NVIDIA fix: patch GradientCanvas/GradientCache to avoid nested QSGRhiLayer::grab crash
# hash: {{ include ".chezmoiexternal.toml" | sha256sum }}

set -euo pipefail

AMBXST_DIR="$HOME/.local/src/ambxst"
CANVAS="$AMBXST_DIR/modules/components/GradientCanvas.qml"
CACHE="$AMBXST_DIR/modules/components/GradientCache.qml"

if [[ ! -d "$AMBXST_DIR" ]]; then
    echo "[ ~ ] Ambxst not cloned yet, skipping NVIDIA patch"
    exit 0
fi

# Patch GradientCanvas.qml — add FBO renderTarget
if ! grep -q 'renderTarget: Canvas.FramebufferObject' "$CANVAS"; then
    echo "[ ~ ] Patching GradientCanvas.qml (FBO render target)..."
    sed -i '/visible: false/a\    renderTarget: Canvas.FramebufferObject\n    renderStrategy: Canvas.Cooperative' "$CANVAS"
else
    echo "[ ~ ] GradientCanvas.qml already patched"
fi

# Patch GradientCache.qml — remove ShaderEffectSource, return Canvas directly
if grep -q 'ShaderEffectSource' "$CACHE"; then
    echo "[ ~ ] Patching GradientCache.qml (remove ShaderEffectSource)..."

    # Replace the _createTextureEntry function body
    python3 -c "
import re

with open('$CACHE', 'r') as f:
    content = f.read()

# Replace the docstring
content = content.replace(
    'Create a Canvas and ShaderEffectSource pair for the gradient.',
    '''Create a Canvas for the gradient.
     * Uses Canvas.FramebufferObject rendering so the Canvas itself acts as
     * a texture provider, avoiding ShaderEffectSource and the nested
     * QSGRhiLayer::grab crash on NVIDIA.'''
)

# Remove '// Create Canvas' comment
content = content.replace('        // Create Canvas\n', '')

# Remove ShaderEffectSource block and return canvas directly
old_block = re.search(
    r'        // Create ShaderEffectSource.*?return \{.*?source: sourceComponent,.*?canvas: canvas,.*?key: key.*?\};',
    content,
    re.DOTALL
)
if old_block:
    content = content[:old_block.start()] + '''        return {
            source: canvas,
            canvas: canvas,
            key: key
        };''' + content[old_block.end():]

with open('$CACHE', 'w') as f:
    f.write(content)
"
else
    echo "[ ~ ] GradientCache.qml already patched"
fi

echo "[ ~ ] Ambxst NVIDIA patch complete"

{{ end -}}
{{ end -}}
