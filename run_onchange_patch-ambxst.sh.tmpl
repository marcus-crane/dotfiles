{{- if (eq .chezmoi.os "linux") -}}
{{- if eq .chezmoi.osRelease.idLike "arch" -}}
#!/usr/bin/env bash

# Screenshot fix: patch ScreenshotTool to avoid grim screencopy overlay blocking
# hash: {{ include ".chezmoiexternal.toml" | sha256sum }}

set -euo pipefail

AMBXST_DIR="$HOME/.local/src/ambxst"
SCREENSHOT="$AMBXST_DIR/modules/services/Screenshot.qml"
TOOL="$AMBXST_DIR/modules/tools/ScreenshotTool.qml"

if [[ ! -d "$AMBXST_DIR" ]]; then
    echo "[ ~ ] Ambxst not cloned yet, skipping screenshot patch"
    exit 0
fi

# Patch Screenshot.qml — add cancel() function after _freezing property
if ! grep -q 'function cancel()' "$SCREENSHOT"; then
    echo "[ ~ ] Patching Screenshot.qml (add cancel function)..."
    sed -i '/property bool _freezing: false/a\
\
    function cancel() {\
        if (freezeProcess.running) {\
            freezeProcess.running = false;\
        }\
        _freezing = false;\
    }' "$SCREENSHOT"
else
    echo "[ ~ ] Screenshot.qml already patched"
fi

# Patch ScreenshotTool.qml — remove "loading" state before freezeScreen
if grep -q 'screenshotPopup.state = "loading"' "$TOOL"; then
    echo "[ ~ ] Patching ScreenshotTool.qml (remove loading state before freeze)..."
    sed -i '/screenshotPopup.state = "loading";/,/\/\/ Trigger freeze/{
        /screenshotPopup.state = "loading";/c\        // Don'\''t set state to "loading" — keep window invisible while grim runs.\
        // The overlay window blocks grim'\''s screencopy protocol, so grim must\
        // finish before the window becomes visible (state transitions in\
        // onMonitorScreenshotReady).
        /\/\/ Trigger freeze/d
    }' "$TOOL"
else
    echo "[ ~ ] ScreenshotTool.qml open() already patched"
fi

# Patch ScreenshotTool.qml — add Screenshot.cancel() in close()
if ! grep -q 'Screenshot.cancel()' "$TOOL"; then
    echo "[ ~ ] Patching ScreenshotTool.qml (add cancel on close)..."
    sed -i '/function close() {/a\        Screenshot.cancel();' "$TOOL"
else
    echo "[ ~ ] ScreenshotTool.qml close() already patched"
fi

echo "[ ~ ] Ambxst screenshot patch complete"

{{ end -}}
{{ end -}}
