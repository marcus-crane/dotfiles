{{- if (eq .chezmoi.os "linux") -}}
{{- if eq .chezmoi.osRelease.idLike "arch" -}}
#!/usr/bin/env bash

set -euo pipefail

arch="$(uname -m)"

case "$arch" in
x86_64)   asset="axctl_linux_amd64" ;;
aarch64)  asset="axctl_linux_arm64" ;;
armv7l|armv7|armv6l) asset="axctl_linux_armv7" ;;
*)
	echo "[ ! ] axctl: unsupported architecture: $arch"
	exit 1
	;;
esac

release_api="https://api.github.com/repos/Axenide/axctl/releases/latest"
latest_tag="$(curl -fsL "$release_api" | grep -E '"tag_name"\s*:' | head -n1 | sed -E 's/.*"tag_name"\s*:\s*"([^"]+)".*/\1/')"
if [[ -z "$latest_tag" ]]; then
	echo "[ ! ] axctl: unable to determine latest release tag"
	exit 1
fi

normalize_version() {
	echo "$1" | sed -E 's/^v//' | grep -Eo '[0-9]+(\.[0-9]+)*' | head -n1 || true
}

latest_version="$(normalize_version "$latest_tag")"

target="/usr/local/bin/axctl"
if [[ -x "$target" ]]; then
	current_version="$(normalize_version "$("$target" --version 2>/dev/null || true)")"
	if [[ -n "$current_version" && "$(printf '%s\n%s\n' "$current_version" "$latest_version" | sort -V | head -n1)" == "$latest_version" ]]; then
		echo "[ ~ ] axctl already up to date ($current_version)"
		exit 0
	fi
fi

url="https://github.com/Axenide/axctl/releases/download/${latest_tag}/${asset}"
tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT

echo "[ ~ ] Downloading axctl ${latest_tag} (${asset})..."
curl -fL "$url" -o "$tmp"

sudo install -m 755 "$tmp" /usr/local/bin/axctl
echo "[ ~ ] axctl installed to /usr/local/bin/axctl"

{{ end -}}
{{ end -}}
