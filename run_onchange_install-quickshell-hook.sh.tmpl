{{- if (eq .chezmoi.os "linux") -}}
{{- if eq .chezmoi.osRelease.idLike "arch" -}}
#!/usr/bin/env bash
# Install pacman hook to auto-rebuild quickshell-git with QueuedConnection patch
set -euo pipefail

sudo mkdir -p /etc/pacman.d/hooks

sudo tee /etc/pacman.d/hooks/quickshell-patch-rebuild.hook > /dev/null <<'EOF'
[Trigger]
Operation = Upgrade
Operation = Install
Type = Package
Target = quickshell-git

[Action]
Description = Scheduling quickshell-git rebuild with QueuedConnection patch...
When = PostTransaction
Exec = /home/marcus/.local/bin/quickshell-patch-hook
EOF

echo "[ ~ ] Installed pacman hook: quickshell-patch-rebuild.hook"

{{ end -}}
{{ end -}}
