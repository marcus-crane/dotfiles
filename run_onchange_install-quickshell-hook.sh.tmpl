{{- if (eq .chezmoi.os "linux") -}}
{{- if eq .chezmoi.osRelease.idLike "arch" -}}
#!/usr/bin/env bash
# Install pacman hook to notify when quickshell-git is upgraded
set -euo pipefail

sudo mkdir -p /etc/pacman.d/hooks

sudo tee /etc/pacman.d/hooks/quickshell-patch-rebuild.hook > /dev/null <<'EOF'
[Trigger]
Operation = Upgrade
Operation = Install
Type = Package
Target = quickshell-git

[Action]
Description = Quickshell-git upgraded — manual re-patch needed
When = PostTransaction
Exec = /usr/bin/runuser -u marcus -- env DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus notify-send -u normal "Quickshell" "quickshell-git upgraded — run: rebuild-quickshell"
EOF

echo "[ ~ ] Installed pacman hook: quickshell-patch-rebuild.hook"

{{ end -}}
{{ end -}}
